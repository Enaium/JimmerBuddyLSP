<configuration>
    <appender name="LSP" class="cn.enaium.jimmer.buddy.lsp.log.LspAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger - %msg%n
            </pattern>
        </layout>
    </appender>
    <root level="INFO">
        <appender-ref ref="LSP"/>
    </root>
    <root level="ERROR">
        <appender-ref ref="LSP"/>
    </root>
    <root level="WARNING">
        <appender-ref ref="LSP"/>
    </root>
</configuration>